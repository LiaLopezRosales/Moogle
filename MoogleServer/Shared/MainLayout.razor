@inherits LayoutComponentBase
@inject IJSRuntime JS

<div class="page">
    <nav class="top-bar">
        <button class="theme-btn" @onclick="ToggleTheme" title="Toggle theme / Cambiar tema">
            @ThemeIcon
        </button>
    </nav>
    <main>
        <div class="content">
            @Body
        </div>
    </main>
</div>

@code {
    string Theme { get; set; } = "light";

    string ThemeIcon => Theme == "dark" ? "🌙" : "☀️";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var saved = await JS.InvokeAsync<string>("localStorage.getItem", "moogle_theme");
            if (saved == "dark" || saved == "light") Theme = saved;
        }
        catch { }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("setTheme", Theme);
        }
    }

    async Task ToggleTheme()
    {
        Theme = Theme == "dark" ? "light" : "dark";
        await JS.InvokeVoidAsync("localStorage.setItem", "moogle_theme", Theme);
        await JS.InvokeVoidAsync("setTheme", Theme);
    }
}
